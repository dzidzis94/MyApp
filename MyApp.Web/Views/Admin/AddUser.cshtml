@model MyApp.Web.Models.UserCreateModel
@{
    ViewData["Title"] = "Pievienot Jaunu Lietotāju";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .form-container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            padding: 2rem;
        }

        .user-type-cards {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .user-type-card {
            border: 2px solid #e9ecef;
            border-radius: 8px;
            padding: 1rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .user-type-card:hover {
                border-color: #4361ee;
            }

            .user-type-card.selected {
                border-color: #4361ee;
                background-color: rgba(67, 97, 238, 0.05);
            }

            .user-type-card i {
                font-size: 2rem;
                margin-bottom: 0.5rem;
            }

        .admin-card i {
            color: #4361ee;
        }

        .client-card i {
            color: #4cc9f0;
        }

        .password-field {
            display: none;
        }
    </style>
}

<div class="admin-header">
    <div>
        <h1>Pievienot Jaunu Lietotāju</h1>
        <p class="text-muted mb-0">Pievienojiet jaunu administratoru vai klientu sistēmai</p>
    </div>
    <div>
        <a href="@Url.Action("AllUsers")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Atpakaļ pie lietotājiem
        </a>
    </div>
</div>

<div class="form-container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="AddUser" method="post">
        @Html.AntiForgeryToken()

        <!-- Lietotāja tips -->
        <div class="mb-4">
            <label class="form-label fw-bold">Lietotāja tips *</label>
            <div class="user-type-cards">
                <div class="user-type-card admin-card" onclick="selectUserType('Admin')">
                    <i class="fas fa-user-cog"></i>
                    <div>Administrators</div>
                    <small class="text-muted">Pilnas pieejas tiesības</small>
                </div>
                <div class="user-type-card client-card" onclick="selectUserType('Client')">
                    <i class="fas fa-user-friends"></i>
                    <div>Klients</div>
                    <small class="text-muted">Ierobežotas pieejas tiesības</small>
                </div>
            </div>
            <input type="hidden" asp-for="UserType" id="userTypeInput" />
            <span asp-validation-for="UserType" class="text-danger"></span>
        </div>

        <!-- Pamatinformācija -->
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" placeholder="Ievadiet vārdu" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" placeholder="Ievadiet uzvārdu" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="piemers@epasts.lv" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="+371 2XXXXXXX" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Paroles lauki (tikai adminiem) -->
        <div id="passwordFields" class="password-field">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Vismaz 6 rakstzīmes" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Atkārtojiet paroli" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pogas -->
        <div class="d-flex justify-content-between mt-4">
            <a href="@Url.Action("AllUsers")" class="btn btn-outline-secondary">
                <i class="fas fa-times me-2"></i>Atcelt
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-2"></i>Saglabāt Lietotāju
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Lietotāja tipa izvēle
        function selectUserType(userType) {
            document.getElementById('userTypeInput').value = userType;

            // Noņem selected klasi no visām kartēm
            document.querySelectorAll('.user-type-card').forEach(card => {
                card.classList.remove('selected');
            });

            // Pievieno selected klasi izvēlētajai kartei
            event.currentTarget.classList.add('selected');

            // Rāda/piestiprina paroles laukus tikai adminiem
            const passwordFields = document.getElementById('passwordFields');
            if (userType === 'Admin') {
                passwordFields.style.display = 'block';
                document.getElementById('Password').required = true;
                document.getElementById('ConfirmPassword').required = true;
            } else {
                passwordFields.style.display = 'none';
                document.getElementById('Password').required = false;
                document.getElementById('ConfirmPassword').required = false;
            }
        }

        // Automātiski izvēlās Client kā noklusējumu
        document.addEventListener('DOMContentLoaded', function() {
            selectUserType('Client');
        });
    </script>
}