@model MyApp.Web.Models.UserCreateModel
@{
    ViewData["Title"] = "Rediģēt Lietotāju";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .form-container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            padding: 2rem;
        }

        .user-type-badge {
            font-size: 1rem;
            padding: 0.5rem 1rem;
        }

        .password-field {
            display: none;
        }
    </style>
}

<div class="admin-header">
    <div>
        <h1>Rediģēt Lietotāju</h1>
        <p class="text-muted mb-0">Labojiet lietotāja informāciju</p>
    </div>
    <div>
        <a href="@Url.Action("UserDetails", new { id = Model.Id, userType = Model.UserType })"
           class="btn btn-outline-secondary me-2">
            <i class="fas fa-arrow-left me-2"></i>Atpakaļ uz profilu
        </a>
        <a href="@Url.Action("AllUsers")" class="btn btn-outline-secondary">
            <i class="fas fa-users me-2"></i>Visi lietotāji
        </a>
    </div>
</div>

<div class="form-container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Lietotāja tips (tikai informācijai) -->
    <div class="mb-4 text-center">
        <span class="badge @(Model.UserType == "Admin" ? "bg-primary" : "bg-info") user-type-badge">
            <i class="fas @(Model.UserType == "Admin" ? "fa-user-cog" : "fa-user-friends") me-2"></i>
            @Model.UserType
        </span>
        <p class="text-muted mt-2">Lietotāja tips nevar tikt mainīts</p>
    </div>

    <form asp-action="EditUser" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="id" value="@Model.Id" />
        <input type="hidden" name="userType" value="@Model.UserType" />

        <!-- Pamatinformācija -->
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Paroles lauki (tikai adminiem) -->
        @if (Model.UserType == "Admin")
        {
            <div id="passwordFields">
                <hr />
                <h5>Mainīt paroli</h5>
                <p class="text-muted">Atstājiet tukšu, ja nevēlaties mainīt paroli</p>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Pogas -->
        <div class="d-flex justify-content-between mt-4">
            <div>
                <a href="@Url.Action("UserDetails", new { id = Model.Id, userType = Model.UserType })"
                   class="btn btn-outline-secondary">
                    <i class="fas fa-times me-2"></i>Atcelt
                </a>
            </div>
            <div>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Saglabāt izmaiņas
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Paroles lauku validācija tikai ja ir ievadīta parole
        document.querySelector('form').addEventListener('submit', function(e) {
            const password = document.getElementById('Password')?.value;
            const confirmPassword = document.getElementById('ConfirmPassword')?.value;

            if (password || confirmPassword) {
                if (password !== confirmPassword) {
                    e.preventDefault();
                    alert('Paroles nesakrīt!');
                    return false;
                }

                if (password && password.length < 6) {
                    e.preventDefault();
                    alert('Parolei jābūt vismaz 6 rakstzīmēm!');
                    return false;
                }
            }
        });
    </script>
}