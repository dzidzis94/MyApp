@model Project
@{
    ViewData["Title"] = "Project Details";
}

<h1>@Model.Title</h1>
<p>@Model.Description</p>
<hr />
<p>Here are the sub-sections for this project. Please fill out each one.</p>

<div class="list-group">
    @foreach (var subSection in Model.SubSections)
    {
        <a asp-action="FillSubSection" asp-route-id="@subSection.Id" class="list-group-item list-group-item-action flex-column align-items-start">
            <div class="d-flex w-100 justify-content-between">
                <h5 class="mb-1">@subSection.Title</h5>
            </div>
            <p class="mb-1">@subSection.Description</p>
        </a>
    }
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Back to Available Projects</a>
</div>