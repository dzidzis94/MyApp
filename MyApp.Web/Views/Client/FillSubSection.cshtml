@model SubSectionFillViewModel
@{
    ViewData["Title"] = "Fill Sub-Section";
}

<h1>@Model.Title</h1>

<form asp-action="FillSubSection" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>
    <input type="hidden" asp-for="SubSectionId" />

    <div class="form-group">
        <label asp-for="Content">Your Submission:</label>
        <textarea asp-for="Content" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary">Submit</button>
        <a asp-action="ProjectDetails" asp-route-id="@ViewBag.ProjectId" class="btn btn-secondary">Cancel</a>
    </div>
</form>