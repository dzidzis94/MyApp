@model IEnumerable<Client>
@{
    ViewData["Title"] = "Manage Clients";
}

<h1>Manage Clients</h1>

<p>
    <a asp-action="AddClient" class="btn btn-primary">Add New Client</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>User Name</th>
            <th>Email</th>
            <th>Registered On</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.User.UserName)</td>
                    <td>@Html.DisplayFor(modelItem => item.User.Email)</td>
                    <td>@Html.DisplayFor(modelItem => item.User.CreatedAt)</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center">No clients found.</td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Back to Admin Dashboard</a>
</div>