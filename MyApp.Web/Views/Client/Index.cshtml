@model IEnumerable<Project>
@{
    ViewData["Title"] = "Available Projects";
}

<h1>Available Projects</h1>

@if (Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Project Title</th>
                <th>Description</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Model)
            {
                <tr>
                    <td>@project.Title</td>
                    <td>@project.Description</td>
                    <td>
                        <a asp-action="ProjectDetails" asp-route-id="@project.Id" class="btn btn-primary">View Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No projects are available at the moment.</p>
}