@model IEnumerable<MyApp.Web.Models.Client>

@{
    ViewData["Title"] = "Select Client";
}

<h1>Select Your Profile</h1>
<p>Please select which client you are to view your assigned projects.</p>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger" role="alert">
        @ViewBag.ErrorMessage
    </div>
}

<div class="row mt-4">
    <div class="col-md-6">
        <form asp-action="SelectClient" method="post">
            <div class="form-group">
                <label for="clientId" class="control-label">Select Client:</label>
                <select name="clientId" class="form-control" asp-items="@(new SelectList(Model, "Id", "FirstName"))">
                    <option value="0">-- Please select a client --</option>
                </select>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="View Projects" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-5">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Role Selection</a>
</div>
