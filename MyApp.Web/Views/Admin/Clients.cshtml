@{
    ViewData["Title"] = "Klientu Pārvaldība";
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Klienti - Darbu Uzskaite</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Papildus stili klientu saskarnei */
        .client-card {
            transition: all 0.3s ease;
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }

            .client-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            }

        .client-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: bold;
        }

        .client-status {
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .status-active {
            background-color: rgba(76, 201, 240, 0.15);
            color: var(--success);
        }

        .status-inactive {
            background-color: rgba(108, 117, 125, 0.15);
            color: #6c757d;
        }

        .search-box {
            position: relative;
            max-width: 400px;
        }

            .search-box input {
                padding-left: 45px;
                border-radius: 25px;
                border: 2px solid #e9ecef;
            }

            .search-box i {
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: #6c757d;
            }

        .action-btns .btn {
            padding: 0.4rem 0.8rem;
            border-radius: 8px;
            margin-left: 0.3rem;
        }
    </style>
</head>
<body class="admin-body">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-brand">
            <i class="fas fa-tasks"></i> <span>Darbu Uzskaite</span>
        </div>
        <ul class="sidebar-nav">
            <li><a href="/Admin"><i class="fas fa-home"></i> <span>Sākumlapa</span></a></li>
            <li><a href="/Admin"><i class="fas fa-user-cog"></i> <span>Admin Panelis</span></a></li>
            <li><a href="/Admin/Clients" class="active"><i class="fas fa-users"></i> <span>Klienti</span></a></li>
            <li><a href="#"><i class="fas fa-project-diagram"></i> <span>Projekti</span></a></li>
            <li><a href="#"><i class="fas fa-chart-bar"></i> <span>Atskaites</span></a></li>
            <li><a href="#"><i class="fas fa-cog"></i> <span>Iestatījumi</span></a></li>
            <li><a href="#"><i class="fas fa-sign-out-alt"></i> <span>Iziet</span></a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <div class="admin-header">
            <div>
                <h1>Klientu Pārvaldība</h1>
                <p class="text-muted mb-0">Pārvaldiet visus sistēmas klientus un to informāciju</p>
            </div>
            <div class="user-info">
                <div class="user-avatar">AD</div>
                <div>
                    <div>Admin Lietotājs</div>
                    <small>Pēdējais ielogojies: Šodien, 10:25</small>
                </div>
            </div>
        </div>

        <!-- Action Bar -->
        <div class="quick-actions mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="form-control" placeholder="Meklēt klientus...">
                </div>
                <div>
                    <button class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Pievienot Jaunu Klientu
                    </button>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-3">
                    <select class="form-select">
                        <option selected>Visi klienti</option>
                        <option>Aktīvie klienti</option>
                        <option>Neaktīvie klienti</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select">
                        <option selected>Jaunākie augšā</option>
                        <option>Vecākie augšā</option>
                        <option>Pēc vārda A-Z</option>
                        <option>Pēc vārda Z-A</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Clients Grid -->
        <div class="row g-4">
            <!-- Client Card 1 -->
            <div class="col-md-6 col-lg-4">
                <div class="client-card card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="client-avatar">JS</div>
                            <span class="client-status status-active">Aktīvs</span>
                        </div>

                        <h5 class="card-title">Jānis Bērziņš</h5>
                        <p class="text-muted">SIA "Web Solutions"</p>

                        <div class="client-info mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-envelope text-muted me-2"></i>
                                <small>janis.berzins@example.lv</small>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-phone text-muted me-2"></i>
                                <small>+371 12345678</small>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-briefcase text-muted me-2"></i>
                                <small>3 aktīvi projekti</small>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-light text-dark">
                                <i class="fas fa-calendar me-1"></i>
                                Pievienots: 2023-10-15
                            </span>
                            <div class="action-btns">
                                <button class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Client Card 2 -->
            <div class="col-md-6 col-lg-4">
                <div class="client-card card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="client-avatar">LP</div>
                            <span class="client-status status-active">Aktīvs</span>
                        </div>

                        <h5 class="card-title">Līga Priede</h5>
                        <p class="text-muted">SIA "Design Studio"</p>

                        <div class="client-info mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-envelope text-muted me-2"></i>
                                <small>liga.priede@example.lv</small>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-phone text-muted me-2"></i>
                                <small>+371 23456789</small>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-briefcase text-muted me-2"></i>
                                <small>1 aktīvs projekts</small>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-light text-dark">
                                <i class="fas fa-calendar me-1"></i>
                                Pievienots: 2023-11-02
                            </span>
                            <div class="action-btns">
                                <button class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Client Card 3 -->
            <div class="col-md-6 col-lg-4">
                <div class="client-card card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="client-avatar">AK</div>
                            <span class="client-status status-inactive">Neaktīvs</span>
                        </div>

                        <h5 class="card-title">Andris Kalniņš</h5>
                        <p class="text-muted">SIA "Tech Innovations"</p>

                        <div class="client-info mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-envelope text-muted me-2"></i>
                                <small>andris.kalnins@example.lv</small>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-phone text-muted me-2"></i>
                                <small>+371 34567890</small>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-briefcase text-muted me-2"></i>
                                <small>0 aktīvu projektu</small>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-light text-dark">
                                <i class="fas fa-calendar me-1"></i>
                                Pievienots: 2023-09-20
                            </span>
                            <div class="action-btns">
                                <button class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pagination -->
        <nav class="d-flex justify-content-center mt-5">
            <ul class="pagination">
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1">Iepriekšējā</a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item">
                    <a class="page-link" href="#">Nākamā</a>
                </li>
            </ul>
        </nav>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>