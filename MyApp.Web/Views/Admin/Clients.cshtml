@model IEnumerable<MyApp.Web.Models.Client>

@{
    ViewData["Title"] = "Manage Clients";
}

<h1>Manage Clients</h1>

<p>
    <a asp-action="AddClient" class="btn btn-success">Add New Client</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.FirstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LastName)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.FirstName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.LastName)
                </td>
                <td>
                    <a asp-action="EditClient" asp-route-id="@item.Id" class="btn btn-warning">Edit</a>
                    <form asp-action="RemoveClient" asp-route-id="@item.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this client?');">Remove</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Back to Admin Dashboard</a>
</div>
